# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional provider defaults for Settings.from_env(prefix="LLM_")
LLM_OPENAI_BASE_URL=
LLM_OPENAI_MODEL=gpt-5-mini
LLM_ANTHROPIC_MODEL=claude-sonnet-4
LLM_GOOGLE_MODEL=gemini-2.0-flash

# Optional cache/runtime defaults
LLM_CACHE_BACKEND=none
LLM_CACHE_DIR=.llm_client_cache
POSTGRES_DSN=postgresql://llm_client:llm_client@127.0.0.1:5434/llm_client
PG_DSN=postgresql://llm_client:llm_client@127.0.0.1:5434/llm_client
REDIS_URL=redis://127.0.0.1:6381/0
QDRANT_URL=http://127.0.0.1:6334
QDRANT_API_KEY=

# Optional agent/logging/metrics defaults
LLM_AGENT_MAX_TURNS=12
LLM_AGENT_TOOL_TIMEOUT=60
LLM_AGENT_BATCH_CONCURRENCY=4
LLM_LOG_LEVEL=INFO
LLM_LOG_FORMAT=text
LLM_METRICS_ENABLED=false
LLM_METRICS_PROVIDER=none
LLM_METRICS_PROMETHEUS_PORT=9000
LLM_METRICS_OTEL_ENDPOINT=

# Optional model catalog overrides
LLM_CLIENT_MODEL_CATALOG_PATH=
LLM_CLIENT_MODEL_CATALOG_OVERRIDE_PATH=

# Optional streaming relay integration
PUSHER_AUTH_KEY=
PUSHER_AUTH_SECRET=
PUSHER_AUTH_VERSION=
PUSHER_APP_CLUSTER=
PUSHER_APP_ID=

# Cookbook/example defaults
LLM_CLIENT_EXAMPLE_ALLOW_SKIP=1
LLM_CLIENT_EXAMPLE_PROVIDER=openai
LLM_CLIENT_EXAMPLE_MODEL=gpt-5-nano
LLM_CLIENT_EXAMPLE_SECONDARY_PROVIDER=anthropic
LLM_CLIENT_EXAMPLE_SECONDARY_MODEL=claude-opus-4
LLM_CLIENT_EXAMPLE_EMBEDDINGS_PROVIDER=openai
LLM_CLIENT_EXAMPLE_EMBEDDINGS_MODEL=text-embedding-3-small
LLM_CLIENT_EXAMPLE_SECONDARY_EMBEDDINGS_PROVIDER=google
LLM_CLIENT_EXAMPLE_SECONDARY_EMBEDDINGS_MODEL=gemini-embedding-001
LLM_CLIENT_EXAMPLE_PG_DSN=postgresql://llm_client:llm_client@127.0.0.1:5434/llm_client
LLM_CLIENT_MISSION_DEBUG=0
